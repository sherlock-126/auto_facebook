{
  "name": "auto_facebook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Facebook joined-groups scraper -> Postgres warehouse (MISA-pattern: noVNC login + XHR discover + GraphQL replay)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "etl": "tsx src/cli.ts",
    "scheduler": "tsx src/scheduler.ts",
    "stack:up": "bash scripts/start-browser-stack.sh",
    "stack:down": "bash scripts/stop-browser-stack.sh",
    "db:init": "bash scripts/init-db.sh",
    "db:migrate": "PGPASSWORD=$(grep ^PG_PASSWORD .env | cut -d= -f2) psql -h $(grep ^PG_HOST .env | cut -d= -f2) -p $(grep ^PG_PORT .env | cut -d= -f2) -U $(grep ^PG_USER .env | cut -d= -f2) -d $(grep ^PG_DATABASE .env | cut -d= -f2) -v ON_ERROR_STOP=1",
    "build-agent": "bash scripts/build-agent.sh",
    "typecheck": "tsc --noEmit",
    "build:css":     "tailwindcss -i ./src/styles.css -o ./public/tailwind.css --minify",
    "build:css:dev": "tailwindcss -i ./src/styles.css -o ./public/tailwind.css --watch"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "@google/genai": "^2.4.0",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "jose": "^6.2.3",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "playwright": "^1.48.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
