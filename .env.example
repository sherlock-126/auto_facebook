# ============ Postgres (native, separate port from MISA's 5433) ============
PG_HOST=127.0.0.1
PG_PORT=5434
PG_USER=fb_etl
PG_PASSWORD=CHANGE_ME
PG_DATABASE=fb_warehouse

# ============ App server ============
APP_PORT=4200
APP_HOST=0.0.0.0

# ============ Browser stack (separate DISPLAY/ports from MISA's :200/5910/6090) ============
XVFB_DISPLAY=:201
VNC_RFB_PORT=5911
NOVNC_WEB_PORT=6091
VNC_PASSWORD=CHANGE_ME

CHROME_PATH=/usr/bin/google-chrome
# Set "true" for local dev (no Xvfb); "false" on VPS (uses XVFB_DISPLAY).
BROWSER_HEADLESS=false

# ============ Facebook scraping budget ============
FB_DELAY_MIN_SEC=25
FB_DELAY_MAX_SEC=55
FB_DAILY_REQUEST_BUDGET=400

# ============ Cron ============
CRON_INCR="*/30 * * * *"
CRON_FULL="0 3 * * *"

# ============ Alerts ============
ALERT_WEBHOOK_URL=

# ============ Public URLs ============
# APP_PUBLIC_BASE_URL is the canonical public origin used in emails, the agent
# install command, and Telegram deep-links. Set it to your real domain.
APP_PUBLIC_BASE_URL=https://nextclaw.vn
NOVNC_PUBLIC_URL=https://fb-vnc.example.com

# ============ Auth / session ============
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
SESSION_COOKIE_NAME=fb_sid
SESSION_TTL_HOURS=12
# Leave UNSET to bind the session cookie to the exact host (keeps admin.* and the
# main host sessions separate). Set to ".example.com" only to share across subdomains.
# SESSION_COOKIE_DOMAIN=.nextclaw.vn

# ============ Admin console ============
# Comma-separated emails allowed to use the admin console at ADMIN_HOST.
ADMIN_EMAILS=you@example.com
ADMIN_HOST=admin.nextclaw.vn

# ============ Multi-tenant / internal ============
# Tenant used by internal-token calls (ops health, etc). On a fresh DB use 'default'.
DEFAULT_TENANT_ID=default
INTERNAL_API_TOKEN=CHANGE_ME_openssl_rand_hex_24
# Cloud-only deploy (no browser; scraping runs on customer agents). Set "1" on the cloud.
CLOUD_ONLY=0
# Port the prod app container binds on the host (nginx proxies here).
NEXTCLAW_PORT=4210

# ============ Email (Resend) ============
RESEND_API_KEY=CHANGE_ME
RESEND_FROM=noreply@nextclaw.vn

# ============ Gemini (lead classifier) ============
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.5-flash
